DATABASE_URL="postgresql://user:password@localhost:5432/arbostar"
DATABASE_URL_TEST="postgresql://user:password@localhost:5432/arbostar_test"
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# SMTP for the "Save and Send" client-approval email. For local dev, generate
# a free disposable Ethereal test account (nodemailer.createTestAccount()) —
# emails aren't really delivered, just viewable at https://ethereal.email.
# For production, swap in real SMTP credentials (Gmail app password, etc.) —
# no code changes needed, only these values.
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="change-me"
SMTP_PASS="change-me"
SMTP_FROM="Arbostar Quotes <change-me@example.com>"
